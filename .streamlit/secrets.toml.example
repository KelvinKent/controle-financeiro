# Modelo de secrets. Copie para secrets.toml e preencha.
# Em deploy (Railway/Render), defina estes valores como variáveis de ambiente
# no painel da plataforma — NÃO suba o secrets.toml real para o repositório.

# Senha de acesso ao app. Deixe vazio para liberar acesso (uso local).
APP_PASSWORD = "troque-por-uma-senha-forte"

# Chave da API Anthropic (opcional — usada na aba Importar).
ANTHROPIC_API_KEY = "sk-ant-..."

# Banco de dados Postgres (Supabase) para deploy com persistência.
# Sem esta variável, o app usa o Excel local. Use a "Session pooler" do Supabase.
DATABASE_URL = "postgresql://postgres.xxxx:SENHA@aws-0-regiao.pooler.supabase.com:5432/postgres"
